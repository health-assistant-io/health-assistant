# Health Assistant — Docker environment template.
# Copy to .env and edit. See docs/INSTALL.md for production guidance.

# ─── Application ───────────────────────────────────────────────────────────
APP_ENV=development              # development | production
DEBUG=true                       # set false for production

# SECRET_KEY signs JWTs. REQUIRED in production — boot refuses to start
# without an explicit value when APP_ENV=production. (Auto-generated by setup_env.py, 
# or generate manually: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=change_this_to_a_secure_random_string

# INTEGRATION_SECRET_KEY is a Fernet key that encrypts integration OAuth
# tokens AND AI provider api_keys at rest. REQUIRED in production. (Auto-generated 
# by setup_env.py, or generate manually: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
INTEGRATION_SECRET_KEY=

# Public base URL of the deployment (used for OAuth redirects, Web Push,
# FHIR facade absolute URLs). Example: https://health.example.com
APP_URL=

# ─── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_DB=health_assistant
POSTGRES_USER=admin
# REQUIRED in production — boot refuses known-weak values (admin123 etc.).
POSTGRES_PASSWORD=secure_password_here
POSTGRES_PORT=5432

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── Backend / Frontend / Flower ports & bindings ──────────────────────────
# Defaults bind to 127.0.0.1 (loopback only) — safe behind a reverse proxy.
# Set to 0.0.0.0 to expose directly (NOT recommended in production).
BACKEND_PORT=8000
BACKEND_BIND=127.0.0.1
FRONTEND_PORT=3000
FRONTEND_BIND=127.0.0.1
FLOWER_PORT=5555
FLOWER_BIND=127.0.0.1

# Flower HTTP basic-auth (REQUIRED for production — without it, anyone with
# network access can inspect task payloads, retry jobs, and read worker state).
FLOWER_USER=admin
FLOWER_PASSWORD=change_this_to_a_secure_password

# ─── Dev tooling — UI screenshot capture ──────────────────────────────────
# Used by scripts/capture_ui.sh and frontend/tests-e2e/ui-capture/capture.mjs.
# HA_FRONTEND_URL / HA_API_URL are optional — if unset, capture builds them
# from FRONTEND_PORT / BACKEND_PORT above. Override only for non-local hosts.
# HA_FRONTEND_URL=http://localhost:3000
# HA_API_URL=http://localhost:8000/api/v1
HA_DEMO_EMAIL=demo@healthassistant.local
HA_DEMO_PASSWORD=Demo1234!

# ─── Celery worker tuning ─────────────────────────────────────────────────
CELERY_WORKER_CONCURRENCY=2      # simultaneous tasks per worker container
CELERY_MAX_TASKS_PER_CHILD=100   # recycle worker process after N tasks (frees leaked memory)

# Resource limits (docker-compose.prod.yml only). Defaults are conservative.
BACKEND_MEMORY=1G
BACKEND_CPUS=1.0
WORKER_MEMORY=2G
WORKER_CPUS=2.0

# Log rotation per container.
LOG_MAX_SIZE=10m
LOG_MAX_FILE=3

# ─── Security ──────────────────────────────────────────────────────────────
JWT_EXPIRATION_HOURS=24


# ───────────────────────────────────────────────────────────────────────────
# ─── OPTIONAL SETTINGS ─────────────────────────────────────────────────────
# ───────────────────────────────────────────────────────────────────────────

# ─── AI / OCR ──────────────────────────────────────────────────────────────
# Health Assistant allows configuring AI providers, API keys, multiple models, 
# and task assignments directly from the UI (System Admin > Tenant Admin > User).
# These environment variables act merely as a global fallback.

# OPENAI_API_KEY=
# OPENAI_API_BASE=
# OPENAI_MODEL=
# OCR_PROVIDER=openai

# ─── Email ────────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=noreply@health-assistant.local

# ─── Web Push (VAPID) — required in production for browser notifications ───
# REQUIRED in production — boot refuses to start without these when
# APP_ENV != "development" (see config.py prod-guard).
# Generate either with: scripts/setup_env.py (auto-fills these), OR manually
# with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_ADMIN_EMAIL=admin@example.com

# ─── MCP Client Integration (integrations/mcp_client/) ────────────────────
# Comma-separated allowlist of base commands users may launch via STDIO MCP.
# MCP_STDIO_ALLOWED_COMMANDS=npx,uvx,python,python3,node
# Resource / concurrency caps:
# MCP_MAX_SERVERS_PER_USER=5
# MCP_MAX_TOTAL_STDIO=20
# MCP_REQUEST_TIMEOUT=30
# MCP_TOOL_RESULT_MAX_BYTES=65536
# INTEGRATION_MAX_TOOLS_PER_SESSION=20
# MCP_CONNECTION_IDLE_TIMEOUT=900
# MCP_PER_INSTANCE_CONCURRENCY=4
# Allow http:// URLs for HTTP/SSE MCP servers (NOT recommended in production).
# MCP_ALLOW_INSECURE_HTTP=False

# ─── File Storage ──────────────────────────────────────────────────────────
# UPLOAD_DIR=/var/healthassistant/uploads
# MAX_UPLOAD_SIZE=50

# ─── Production image registry (docker-compose.prod.yml only) ─────────────
# Pre-built images must exist at this path. CI/CD normally publishes them.
# REGISTRY=ghcr.io
# REPOSITORY=health-assistant
# IMAGE_TAG=latest

