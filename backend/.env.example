# Health Assistant Backend Environment Configuration
# Copy this file to .env and update with your values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=Health Assistant
APP_ENV=development
DEBUG=True

# Public-facing URLs (used for CORS and Web Push VAPID claims).
# APP_URL is this backend's public base; FRONTEND_URL is the frontend origin.
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Cap on agent reasoning iterations for the AI chat (1-100).
AI_AGENT_MAX_ITERATIONS=20

# =============================================================================
# DATABASE SETTINGS
# =============================================================================
DATABASE_URL=postgresql+asyncpg://admin:admin123@localhost:5432/health_assistant
DATABASE_POOL_SIZE=10

# PostgreSQL (for Docker)
POSTGRES_DB=health_assistant
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_PORT=5432

# =============================================================================
# REDIS SETTINGS
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# IMPORTANT: Change this in production! Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# =============================================================================
# OPENAI / AI SETTINGS (OpenAI-Compatible APIs)
# =============================================================================
# OCR Provider: openai, tesseract
OCR_PROVIDER=openai

# OpenAI API Configuration
# Works with any OpenAI-compatible API (OpenAI, Azure, etc.)
OPENAI_API_KEY=your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-vision-preview
OPENAI_MAX_TOKENS=4096
OPENAI_TIMEOUT=30

# =============================================================================
# MCP CLIENT INTEGRATION (integrations/mcp_client/)
# =============================================================================
# Fernet key (base64 32-byte) used to encrypt secrets at rest. As of 0.3.0 this
# key is used for BOTH:
#   - MCP/integration secrets in user_integrations.user_config
#   - AIProviderModel.api_key (audit B1)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED in production — if unset, AI keys are stored in PLAINTEXT with a warning.
# Existing plaintext AI keys can be migrated post-deploy via:
#   PYTHONPATH=. python scripts/encrypt_existing_api_keys.py [--dry-run]
INTEGRATION_SECRET_KEY=

# Comma-separated allowlist of base commands users may launch via STDIO MCP.
MCP_STDIO_ALLOWED_COMMANDS=npx,uvx,python,python3,node

# Resource / concurrency caps.
MCP_MAX_SERVERS_PER_USER=5
MCP_MAX_TOTAL_STDIO=20
MCP_REQUEST_TIMEOUT=30
MCP_TOOL_RESULT_MAX_BYTES=65536
INTEGRATION_MAX_TOOLS_PER_SESSION=20
MCP_CONNECTION_IDLE_TIMEOUT=900
MCP_PER_INSTANCE_CONCURRENCY=4
# Allow http:// URLs for HTTP/SSE MCP servers (NOT recommended in production).
MCP_ALLOW_INSECURE_HTTP=False

# Examples for different providers:

# OpenAI (default):
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4-vision-preview

# Azure OpenAI:
# OPENAI_API_BASE=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# OPENAI_MODEL=your-deployment-name

# Local Ollama:
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_MODEL=llava

# Together AI:
# OPENAI_API_BASE=https://api.together.xyz/v1
# OPENAI_MODEL=meta-llama/Llama-2-70b-chat-hf

# =============================================================================
# FILE STORAGE SETTINGS
# =============================================================================
UPLOAD_DIR=/var/healthassistant/uploads
MAX_UPLOAD_SIZE=50

# =============================================================================
# EMAIL SETTINGS
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@healthassistant.local

# =============================================================================
# PORT SETTINGS (for Docker)
# =============================================================================
BACKEND_PORT=8000
FRONTEND_PORT=3000
FLOWER_PORT=5555

# =============================================================================
# WEB PUSH (VAPID) SETTINGS — required for browser push notifications
# =============================================================================
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=mailto:admin@example.com
