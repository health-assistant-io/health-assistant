# Health Assistant — Docker environment template.
# Copy to .env and edit. See docs/INSTALL.md for production guidance.

# ─── Application ───────────────────────────────────────────────────────────
APP_ENV=development              # development | production
DEBUG=true                       # set false for production

# SECRET_KEY signs JWTs. REQUIRED in production — boot refuses to start
# without an explicit value when APP_ENV=production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_this_to_a_secure_random_string

# INTEGRATION_SECRET_KEY is a Fernet key that encrypts integration OAuth
# tokens AND AI provider api_keys at rest. REQUIRED in production. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INTEGRATION_SECRET_KEY=

# Public base URL of the deployment (used for OAuth redirects, Web Push,
# FHIR facade absolute URLs). Example: https://health.example.com
APP_URL=

# ─── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_DB=health_assistant
POSTGRES_USER=admin
# REQUIRED in production — boot refuses known-weak values (admin123 etc.).
POSTGRES_PASSWORD=secure_password_here
POSTGRES_PORT=5432

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── Backend / Frontend / Flower ports & bindings ──────────────────────────
# Defaults bind to 127.0.0.1 (loopback only) — safe behind a reverse proxy.
# Set to 0.0.0.0 to expose directly (NOT recommended in production).
BACKEND_PORT=8000
BACKEND_BIND=127.0.0.1
FRONTEND_PORT=3000
FRONTEND_BIND=127.0.0.1
FLOWER_PORT=5555
FLOWER_BIND=127.0.0.1

# Flower HTTP basic-auth (REQUIRED for production — without it, anyone with
# network access can inspect task payloads, retry jobs, and read worker state).
FLOWER_USER=admin
FLOWER_PASSWORD=change_this_to_a_secure_password

# ─── Celery worker tuning ─────────────────────────────────────────────────
CELERY_WORKER_CONCURRENCY=2      # simultaneous tasks per worker container
CELERY_MAX_TASKS_PER_CHILD=100   # recycle worker process after N tasks (frees leaked memory)

# Resource limits (docker-compose.prod.yml only). Defaults are conservative.
BACKEND_MEMORY=1G
BACKEND_CPUS=1.0
WORKER_MEMORY=2G
WORKER_CPUS=2.0

# Log rotation per container.
LOG_MAX_SIZE=10m
LOG_MAX_FILE=3

# ─── AI / OCR ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=
OPENAI_MODEL=
OCR_PROVIDER=openai

# ─── Email (optional) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@health-assistant.local

# ─── Web Push (VAPID) — required for browser notifications ────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Security ──────────────────────────────────────────────────────────────
JWT_EXPIRATION_HOURS=24

# ─── Production image registry (docker-compose.prod.yml only) ─────────────
# Pre-built images must exist at this path. CI/CD normally publishes them.
REGISTRY=ghcr.io
REPOSITORY=health-assistant
IMAGE_TAG=latest
